{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "_parked",
    "supabase/functions/mpesa-stk-push/index.ts",
    "supabase/functions/mpesa-callback/index.ts",
    "supabase/functions/_shared/daraja-client.ts",
    "supabase/functions/register-device/index.ts",
    "supabase/functions/send-push/index.ts",
    "supabase/functions/_shared/expo-push-client.ts"
  ]
}
