EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── M-Pesa / Daraja Edge Function secrets ────────────────────────────────────
# Real values are set via `supabase secrets set KEY=value` and are NEVER committed.
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# auto-provided to Edge Functions by the Supabase runtime — do NOT set them here.
#
# Set MPESA_MODE to 'mock' (default), 'sandbox', or 'live'.
MPESA_MODE=mock
# Daraja base URL (sandbox: https://sandbox.safaricom.co.ke, live: https://api.safaricom.co.ke)
DARAJA_BASE_URL=
# Daraja API credentials from the Safaricom developer portal.
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
# Business Short Code (paybill or till number).
DARAJA_SHORTCODE=
# Lipa Na M-Pesa Online passkey.
DARAJA_PASSKEY=
# Public HTTPS URL Daraja will POST the STK Push result to (the mpesa-callback function URL).
DARAJA_CALLBACK_URL=
# Shared secret appended as ?token=… to the callback URL to gate unauthorized POSTs.
MPESA_CALLBACK_SECRET=

# ─── Push notification Edge Function secret ────────────────────────────────────
# High-entropy shared secret sent in the `x-webhook-secret` header by the
# Supabase database webhook to authorize calls to the send-push function.
# Set the real value via:  supabase secrets set PUSH_WEBHOOK_SECRET=<value>
# This value is ALSO mirrored into `private.push_config.webhook_secret` (later task).
# NEVER commit the real value here — this file is a template only.
PUSH_WEBHOOK_SECRET=
